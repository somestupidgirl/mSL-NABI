#! /usr/bin/perl

use strict;
use warnings;
use Getopt::Long;
use Pod::Usage;
use File::stat;
use Cwd;

our $VERSION = "@PROJECT_VERSION@";

my ($root, $strace, $output);

GetOptions(
  'root=s' => \$root,
  'strace=s' => \$strace,
  'output=s' => \$output,
  'h|help' => sub {
    pod2usage(1);
  },
  'v|version' => sub {
    print "$VERSION\n";
    exit 0;
  }
) or exit 1;

my $nabidir = "$ENV{HOME}/.nabi";

if (! -d $nabidir) {
  mkdir $nabidir;
}

if (! defined $root) {
  $root = "$nabidir/tree";

  # Adopt a rootfs left by the pre-rename install rather than provisioning a
  # second one. It may be several gigabytes, and re-downloading it just because
  # the command changed name would be a hostile way to ship a rename.
  my $legacy = "$ENV{HOME}/.noah/tree";
  if (! -d $root && -d $legacy) {
    print "nabi: adopting the existing filesystem at ~/.noah/tree.\n";
    if (system("/bin/mv", $legacy, $root) == 0) {
      rmdir "$ENV{HOME}/.noah";
    } else {
      print "nabi: could not move it; using it where it is.\n";
      $root = $legacy;
    }
  }

  if (! -d $root) {
    prompt_yn("nabi is installing the initial filesystem in ~/.nabi/tree. Proceed? [Y/n]", "y") or exit 1;
    system "sudo noahstrap -p ubuntu $root";
  }
}

my $nabi = "@PREFIX@/libexec/nabi";

if ($> != 0) {
  my $st = stat $nabi;
  if ($st->uid != 0 || ($st->mode & 04000) == 0) {
    if (prompt_yn("Allow nabi to run as root? It's necessary for privileged commands such as sudo.\nnabi is still under development, so please enable it at your own risk! [y/N]", "n")) {
      system "sudo chown root:admin $nabi";
      system "sudo chmod u+s $nabi";
    } else {
      print "* Running nabi as normal user... This may cause unstable behavior of sudo executed from inside nabi.\n";
    }
  }
}

my $init = "/bin/bash -i";
if (@ARGV != 0) {
  $init = join(" ", map {"'$_'"} @ARGV);
}

my $opts = "";
if (defined $strace) {
  $opts .= "--strace $strace ";
}
if (defined $output) {
  $opts .= "--output $output ";
}

#system "lldb -- ${nabi} -m $root $opts $init";
system "${nabi} -m $root $opts $init";

sub prompt_yn {
  my ($query, $default) = @_;
  my $ans = prompt($query);
  $ans = $default if ($ans eq '');
  return ($ans eq 'y' or $ans eq 'Y');
}

sub prompt {
  my ($query) = @_; # take a prompt string as argument
  local $| = 1; # activate autoflush to immediately show the prompt
  print $query . " ";
  chomp(my $answer = <STDIN>);
  return $answer;
}

__END__

=head1 NAME

nabi -- macOS Subsystem for Linux

=head1 SYNOPSIS

    nabi [OPTION...]
    nabi [OPTION...] path_to_executable [ARG...]

=head1 DESCRIPTION

TBA

=head1 OPTIONS

=head2 --root=DIR

Use DIR as root fs.

=head2 --help, -h

Shows this message.

=head2 --version, -v

Shows version information.

